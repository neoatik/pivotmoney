# Database — local PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/pivotmoney

# Gemini API Key (get from https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# App settings
APP_NAME=PivotMoney Ingestion Engine
DEBUG=true
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
